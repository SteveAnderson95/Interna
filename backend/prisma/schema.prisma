generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  COMPANY
  SCHOOL
  ADMIN
}

enum ApplicationStatus {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
  BLOQUEE
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      UserRole
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student?
  company   Company?
  school    School?
}

model Student {
  id           Int           @id @default(autoincrement())
  userId       Int           @unique
  schoolId     Int?
  firstName    String
  lastName     String
  fieldOfStudy String
  studyLevel   String
  city         String?
  phone        String?
  bio          String?
  cvUrl        String?
  photoUrl     String?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  school       School?       @relation(fields: [schoolId], references: [id])
  applications Application[]
  internships  Internship[]
}

model Company {
  id          Int               @id @default(autoincrement())
  userId      Int               @unique
  name        String
  sector      String?
  city        String?
  description String?
  phone       String?
  website     String?
  address     String?
  contactName String?
  photoUrl    String?
  galleryUrls Json?

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers      InternshipOffer[]
  internships Internship[]
}

model School {
  id       Int       @id @default(autoincrement())
  userId   Int       @unique
  name     String
  city     String?
  phone    String?
  website  String?
  address  String?
  photoUrl String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students Student[]
}

model InternshipOffer {
  id           Int           @id @default(autoincrement())
  companyId    Int
  title        String
  description  String
  fieldOfStudy String
  studyLevel   String
  duration     String?
  internshipType String?
  city         String?
  status       String        @default("ouverte")
  deadline     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
}

model Application {
  id                  Int               @id @default(autoincrement())
  studentId           Int
  internshipOfferId   Int
  motivationLetterUrl String
  conventionUrl       String
  status              ApplicationStatus @default(EN_ATTENTE)
  blockReason         String?
  createdAt           DateTime          @default(now())

  student             Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  internshipOffer     InternshipOffer   @relation(fields: [internshipOfferId], references: [id], onDelete: Cascade)
  internship          Internship?

  @@unique([studentId, internshipOfferId])
}

model Internship {
  id            Int          @id @default(autoincrement())
  applicationId Int          @unique
  studentId     Int
  companyId     Int
  title         String
  status        String       @default("en_cours")
  startedAt     DateTime     @default(now())
  validatedAt   DateTime?
  createdAt     DateTime     @default(now())

  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  student       Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deliverables  Deliverable[]
  evaluation    Evaluation?
}

model Deliverable {
  id           Int        @id @default(autoincrement())
  internshipId Int
  title        String
  fileUrl      String
  createdAt    DateTime   @default(now())

  internship   Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
}

model Evaluation {
  id           Int        @id @default(autoincrement())
  internshipId Int        @unique
  notes        String?
  createdAt    DateTime   @default(now())

  internship   Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
}
